# GenreTV on managed Supabase + Electric Cloud.
# Copy to `genretv.cloud.env` (gitignored), fill in real values, then use the `cloud:*` scripts.
# Project creation, Electric source creation, and `supabase link` are one-time manual steps.

# Supabase project URL and public browser key.
GENRETV_SUPABASE_URL=https://YOUR_REF.supabase.co
GENRETV_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxx_xxxxxxxx

# Direct Postgres connection: Drizzle migrations and explicit canonical bootstrap seeding.
GENRETV_DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_REF.supabase.co:5432/postgres

# Transaction pooler shown for reference. Supabase Cloud injects SUPABASE_DB_URL into Edge Functions;
# do not attempt to set that reserved secret yourself.
GENRETV_DB_POOLER_URL=postgresql://postgres.YOUR_REF:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# Database region. cloud:dev passes this to the browser so DB-bound writes invoke the Edge Function nearby.
GENRETV_FUNCTIONS_REGION=REGION

# Server-side Electric endpoint. cloud:secrets installs it in the linked Supabase project; it is never
# exposed to Vite or the browser.
ELECTRIC_SHAPE_URL=https://YOUR_SOURCE_ID.electric-sql.cloud/v1/shape?source_id=YOUR_SOURCE_ID&secret=YOUR_SOURCE_SECRET

# cloud:dev derives VITE_GENRETV_* from the values above. Uncomment only to override the browser target.
# VITE_GENRETV_SUPABASE_URL=https://YOUR_REF.supabase.co
# VITE_GENRETV_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxx_xxxxxxxx
# VITE_GENRETV_FUNCTIONS_REGION=REGION

# CORS allow-list installed by cloud:secrets. Origins have no path component.
GENRETV_ALLOWED_ORIGINS=https://genretv.github.io,http://localhost:5660,http://127.0.0.1:5660
