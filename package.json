{
  "name": "genretv",
  "private": true,
  "license": "MIT",
  "workspaces": [
    "apps/*"
  ],
  "type": "module",
  "scripts": {
    "build": "bun run build:genretv && bun run build:api",
    "build:api": "cd apps/genretv-api && bun run build",
    "build:genretv": "cd apps/genretv && bun run build",
    "dev:api": "cd apps/genretv-api && bun run dev",
    "dev:genretv": "cd apps/genretv && bun run dev",
    "format": "oxfmt --config .oxfmtrc.jsonc --check .",
    "format:write": "oxfmt --config .oxfmtrc.jsonc --write .",
    "lint": "oxlint -c .oxlintrc.jsonc apps/*/src *.ts",
    "lint:fix": "oxlint --fix -c .oxlintrc.jsonc apps/*/src *.ts",
    "preview:genretv": "cd apps/genretv && bun run preview",
    "seed:blogspot": "bun apps/genretv/scripts/extract-blogspot-seed.ts --out apps/genretv/seeds/blogspot-canonical.seed.json",
    "test": "bun run test:api",
    "test:api": "cd apps/genretv-api && bun run test",
    "typecheck": "tsgo --noEmit -p tsconfig.json && tsgo --noEmit -p apps/genretv/tsconfig.json && tsgo --noEmit -p apps/genretv-api/tsconfig.json",
    "validate": "bun run typecheck && bun run lint && bun run test && bun run build"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "26.1.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260703.1",
    "bun-types": "^1.3.14",
    "oxfmt": "0.57.0",
    "oxlint": "1.72.0",
    "oxlint-tsgolint": "0.24.0",
    "tsx": "4.23.0"
  },
  "packageManager": "bun@1.3.14"
}
