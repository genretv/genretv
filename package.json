{
  "name": "genretv",
  "private": true,
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "bun run build:genretv && bun run build:api && bun run build:docs",
    "build:api": "cd apps/genretv-api && bun run build",
    "build:docs": "cd apps/docs && bun run build",
    "build:genretv": "cd apps/genretv && bun run build",
    "build:site": "GENRETV_OUTDIR=../docs/dist VITE_GENRETV_HASH_ROUTING=1 bun run build:genretv && bun run build:docs",
    "cloud:deploy": "bun scripts/genretv-cloud.ts deploy",
    "cloud:dev": "bun scripts/genretv-cloud.ts dev",
    "cloud:functions": "bun scripts/genretv-cloud.ts functions",
    "cloud:migrate": "bun scripts/genretv-cloud.ts migrate",
    "cloud:preview": "bun scripts/genretv-cloud.ts preview",
    "cloud:secrets": "bun scripts/genretv-cloud.ts secrets",
    "cloud:seed": "bun scripts/genretv-cloud.ts seed",
    "db:generate": "drizzle-kit generate --config=infra/drizzle.config.ts",
    "db:migrate": "bun --bun drizzle-kit migrate --config=infra/drizzle.config.ts",
    "db:migrate:local": "bun run db:migrate",
    "db:migrations:regenerate": "bun scripts/regenerate-drizzle-migrations.ts --confirm",
    "db:seed:canonical": "bun apps/genretv/scripts/seed-canonical-registry.ts",
    "db:seed:canonical:local": "bun run db:seed:canonical",
    "db:sync-function:check": "pgxsinkit-generate --utilities --check --project-dir . --config infra/drizzle.config.ts --name 20260708000000_pgxsinkit_utilities && pgxsinkit-generate --check --registry packages/domain/src/registry.ts --export genretvSyncRegistry --project-dir . --config infra/drizzle.config.ts",
    "db:sync-function:generate": "pgxsinkit-generate --registry packages/domain/src/registry.ts --export genretvSyncRegistry --project-dir . --config infra/drizzle.config.ts --name sync_artifact",
    "db:utilities:generate": "pgxsinkit-generate --utilities --project-dir . --config infra/drizzle.config.ts --name 20260708000000_pgxsinkit_utilities",
    "dev:api": "cd apps/genretv-api && bun run dev",
    "dev:bump": "bun scripts/dev-channel.ts bump",
    "dev:docs": "cd apps/docs && bun run dev",
    "dev:genretv": "cd apps/genretv && bun run dev",
    "dev:link": "bun scripts/dev-channel.ts link",
    "dev:status": "bun scripts/dev-channel.ts status",
    "dev:unlink": "bun scripts/dev-channel.ts unlink",
    "docs:screenshots": "playwright test --config apps/docs/playwright.config.ts",
    "edge:build": "bun apps/genretv/scripts/build-edge-functions.ts",
    "format": "oxfmt --config .oxfmtrc.jsonc --check .",
    "format:write": "oxfmt --config .oxfmtrc.jsonc --write .",
    "infra:e2e:down": "GENRETV_INFRA_ENV_FILE=infra/compose/genretv-e2e.env GENRETV_INFRA_LABEL=infra:e2e:down bun --env-file=infra/compose/genretv-e2e.env scripts/infra-stack-down.ts --volumes",
    "infra:e2e:up": "GENRETV_INFRA_ENV_FILE=infra/compose/genretv-e2e.env GENRETV_INFRA_LABEL=infra:e2e:up bun --env-file=infra/compose/genretv-e2e.env scripts/infra-stack-up.ts",
    "infra:local:down": "bun scripts/infra-stack-down.ts",
    "infra:local:logs": "podman compose --env-file infra/compose/genretv.env -f infra/compose/genretv-compose.yml logs -f",
    "infra:local:up": "bun --env-file=infra/compose/genretv.env scripts/infra-stack-up.ts",
    "lint": "oxlint -c .oxlintrc.jsonc apps/*/src packages/*/src apps/*/scripts apps/*/screenshots apps/*/*.ts scripts tests infra *.ts",
    "lint:fix": "oxlint --fix -c .oxlintrc.jsonc apps/*/src packages/*/src apps/*/scripts apps/*/screenshots apps/*/*.ts scripts tests infra *.ts",
    "prepare": "git config core.hooksPath .githooks || true",
    "preview:docs": "cd apps/docs && bun run preview",
    "preview:genretv": "cd apps/genretv && bun run preview",
    "seed:blogspot": "bun apps/genretv/scripts/extract-blogspot-seed.ts --out apps/genretv/seeds/blogspot-canonical.seed.json",
    "seed:canonical": "bun apps/genretv/scripts/build-canonical-registry-seed.ts --out apps/genretv/seeds/canonical-registry.seed.json",
    "seed:canonical:quality": "bun apps/genretv/scripts/check-canonical-seed-quality.ts",
    "test": "bun run test:scripts && bun run test:genretv && bun run test:api",
    "test:api": "cd apps/genretv-api && bun run test",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:offline": "playwright test --config playwright.offline.config.ts",
    "test:genretv": "cd apps/genretv && bun run test",
    "test:integration": "bun test tests/integration",
    "test:integration:live": "GENRETV_RUN_LOCAL_STACK_TESTS=1 bun test tests/integration",
    "test:scripts": "bun test scripts",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p apps/genretv/tsconfig.json && tsc --noEmit -p apps/genretv-api/tsconfig.json && cd apps/docs && bun run check",
    "validate": "bun run typecheck && bun run lint && bun run test && bun run seed:canonical:quality && bun run build && bun run db:sync-function:check",
    "validate:full": "bun run validate && bun run test:integration && bun run test:e2e"
  },
  "dependencies": {},
  "devDependencies": {
    "@pgxsinkit/server": "0.1.40",
    "@playwright/test": "^1.61.1",
    "@tanstack/intent": "^0.3.5",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "bun-types": "^1.3.14",
    "drizzle-kit": "1.0.0-rc.4",
    "drizzle-orm": "1.0.0-rc.4",
    "oxfmt": "0.58.0",
    "oxlint": "1.73.0",
    "oxlint-tsgolint": "0.24.0",
    "tsx": "4.23.0",
    "typescript": "^7.0.2"
  },
  "packageManager": "bun@1.3.14"
}
