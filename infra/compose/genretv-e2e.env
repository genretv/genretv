# GenreTV E2E stack — disposable defaults, not secrets.
# Used only by Playwright/global E2E setup. Keep ports and container names distinct from genretv.env.

GENRETV_COMPOSE_PROJECT=genretv-e2e
GENRETV_DB_CONTAINER=genretv-e2e-db
GENRETV_AUTH_CONTAINER=genretv-e2e-auth
GENRETV_META_CONTAINER=genretv-e2e-meta
GENRETV_STUDIO_CONTAINER=genretv-e2e-studio
GENRETV_FUNCTIONS_CONTAINER=genretv-e2e-functions
GENRETV_ELECTRIC_CONTAINER=genretv-e2e-electric
GENRETV_ENVOY_CONTAINER=genretv-e2e-envoy
GENRETV_CADDY_CONTAINER=genretv-e2e-caddy
GENRETV_USER_SEED_CONTAINER=genretv-e2e-user-seed
GENRETV_FUNCTIONS_DIST=tmp/agents/e2e-functions-dist
GENRETV_FUNCTIONS_MOUNT=../../tmp/agents/e2e-functions-dist

GENRETV_POSTGRES_PORT=55422
GENRETV_AUTH_PORT=55434
GENRETV_STUDIO_PORT=55433
GENRETV_ELECTRIC_PORT=55430
GENRETV_ENVOY_PORT=55431
GENRETV_CADDY_PORT=55443

POSTGRES_PASSWORD=your-super-secret-and-long-postgres-password
POSTGRES_DB=postgres

JWT_EXPIRY=3600
JWT_SECRET=genretv-e2e-unused-placeholder-min-32-characters
GOTRUE_JWT_KEYS=[{"kty":"EC","kid":"genretv-local-es256","use":"sig","key_ops":["sign","verify"],"alg":"ES256","ext":true,"crv":"P-256","x":"E-ojZGYJNkt5_x9cMfoCwRPMUlFW2sOqmzumC_5zcys","y":"oJiPjIrY3O4Rr3EaFnaOw8gn2ZkRDyjlALAj6a_5Pag","d":"H9VQEGODrDB3nIHXNllN-rPownka9zYQjQVR7VZEMII"}]

GENRETV_PUBLISHABLE_KEY=sb_publishable_genretvE2Exxxxxxxxxxxx_demo0000
GENRETV_SECRET_KEY=sb_secret_genretvE2Exxxxxxxxxxxxx_demo0000
GENRETV_API_EXTERNAL_URL=http://localhost:55431
GENRETV_SITE_URL=http://localhost:5174
GENRETV_ALLOWED_ORIGINS=http://localhost:5174,http://127.0.0.1:5174,http://localhost:55431

GENRETV_LOCAL_USER_PASSWORD=genretv-local-password

VITE_GENRETV_SUPABASE_URL=http://localhost:55431
VITE_GENRETV_PUBLISHABLE_KEY=sb_publishable_genretvE2Exxxxxxxxxxxx_demo0000
VITE_GENRETV_FUNCTIONS_REGION=
VITE_GENRETV_HASH_ROUTING=
