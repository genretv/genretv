# Bundled Edge functions (regenerated by `bun run edge:build`)
supabase/functions-dist/
# Supabase CLI local state (project link, etc.) — written by `supabase link`/deploy, never committed
supabase/.temp/
# Local mkcert-issued TLS certs for local h2/h3 fronting.
infra/compose/certs/
# starlight-typedoc generated API reference (regenerated on every docs build)
apps/docs/src/content/docs/api/
.env
# Real Supabase Cloud + Electric Cloud credentials — never commit. Copy from genretv.cloud.env.example.
genretv.cloud.env
# CI-written GitHub Packages auth — never commit a token
.npmrc
# Playwright browser-lane output (traces, last-run) — regenerated by `bun run test:integration:worker`
test-results/
playwright-report/
